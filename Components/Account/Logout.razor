@page "/account/logout"
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject NavigationManager NavigationManager
@inject ILogger<Logout> Logger

<PageTitle>Logout</PageTitle>

<h1>Logout</h1>

<div class="auth-panel">
    <AuthorizeView>
        <Authorized Context="auth">
            <p>You are signed in as @auth.User.Identity?.Name.</p>

            <EditForm Model="Input" FormName="logout" OnValidSubmit="LogoutUser" method="post" Context="form">
                <button type="submit" class="btn btn-primary w-100">Logout</button>
            </EditForm>
        </Authorized>
        <NotAuthorized>
            <p>You are already signed out.</p>
            <a class="btn btn-primary w-100" href="account/login">Login</a>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private object Input { get; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private async Task LogoutUser()
    {
        await SignInManager.SignOutAsync();
        Logger.LogInformation("User logged out.");
        NavigationManager.NavigateTo(GetSafeReturnUrl(), forceLoad: true);
    }

    private string GetSafeReturnUrl()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
        {
            return "/";
        }

        return Uri.TryCreate(ReturnUrl, UriKind.Relative, out _) ? ReturnUrl : "/";
    }
}
